{
  "contract": "livestore/pnpm-install-contract",
  "dependencyGraphContract": {
    "allowBuilds": {
      "@mixedbread/cli": true,
      "@myobie/pty": false,
      "@parcel/watcher": true,
      "cbor-extract": true,
      "dtrace-provider": true,
      "esbuild": false,
      "fsevents": false,
      "msgpackr-extract": false,
      "node-pty": false,
      "protobufjs": true,
      "puppeteer": true,
      "sharp": false,
      "unix-dgram": false,
      "workerd": true
    },
    "packageExtensions": {
      "@livestore/devtools-vite": {
        "dependencies": {
          "@parcel/watcher": "^2.5.6"
        }
      },
      "starlight-auto-sidebar": {
        "dependencies": {
          "astro": ">=6.0.0"
        }
      },
      "starlight-links-validator": {
        "dependencies": {
          "astro": ">=6.0.0"
        }
      },
      "starlight-sidebar-topics": {
        "dependencies": {
          "astro": ">=6.0.0"
        }
      },
      "typedoc": {
        "dependencies": {
          "typedoc-plugin-markdown": "^4.8.1"
        }
      }
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0"
    }
  },
  "dependencyMaterializationProfile": {
    "buck2Boundary": {
      "consumesEvidence": true,
      "ownsLiveMaterialization": false
    },
    "identityInputs": [
      "packageManager",
      "dependencyGraphContract",
      "installPolicy",
      "storeContract",
      "workspaceManifestContract"
    ],
    "nativeBuildPolicyInputs": {
      "allowBuilds": "dependencyGraphContract.allowBuilds",
      "compilerEnv": ["CC", "CXX"]
    },
    "schema": "dependency-materialization-profile/v0",
    "supportedTraits": {
      "ciJobLocal": {
        "gcAuthority": "profile-local",
        "mutableState": "job-local",
        "repairAuthority": "ci-job"
      },
      "hostUserStoreCache": {
        "gcAuthority": "host-fleet-maintenance",
        "mutableState": "materialization-root-and-host-user-cache",
        "repairAuthority": "materialization-root",
        "sharedContent": "complete-pnpm-store-cache"
      },
      "nixPreparedDeps": {
        "gcAuthority": "nix-store",
        "mutableState": "none",
        "repairAuthority": "evergreen-fod"
      }
    }
  },
  "installPolicy": {
    "dedupePeerDependents": true,
    "ignoreScripts": true,
    "minimumReleaseAgeExclude": ["@effect/platform", "@types/node", "effect"],
    "optimisticRepeatInstall": false,
    "packageImportMethod": {
      "live": {
        "linuxSameDeviceRequired": true,
        "method": "auto",
        "owner": "pnpm"
      },
      "nixPreparedDependencies": {
        "scope": "independent-builder-policy"
      }
    },
    "pmOnFail": "ignore",
    "sideEffectsCache": false,
    "strictPeerDependencies": false,
    "strictStorePkgContentCheck": true,
    "supportedArchitectures": {
      "cpu": ["x64", "arm64"],
      "libc": ["glibc", "musl"],
      "os": ["linux", "darwin"]
    },
    "verifyDepsBeforeRun": false,
    "verifyStoreIntegrity": true
  },
  "metadata": {
    "buck2Integration": {
      "avoidNodeModulesLayoutAsApi": true,
      "consumeContractArtifact": true
    },
    "nixIntegration": {
      "fixedOutputDependencyPrepUsesSameVirtualStoreScope": true,
      "liveVirtualStoreScope": "materialization-root"
    },
    "pnpmStoreOwnership": {
      "cacheLifecycle": "pnpm-owned disposable Store Cache",
      "derivedIndexLifecycle": "shared only inside one same-user trust boundary",
      "virtualStoreLifecycle": "Materialization-Root-owned rebuildable dependency graph"
    }
  },
  "packageManager": {
    "name": "pnpm",
    "version": "11.8.0"
  },
  "schemaVersion": 2,
  "storeContract": {
    "ci": {
      "scope": "job"
    },
    "layoutVersion": "v11",
    "localDevelopment": {
      "contentAddressedFiles": "shared",
      "defaultPath": "~/.local/share/pnpm/store-shared-v1",
      "derivedIndex": "shared-pnpm-owned",
      "pathOverrideEnvironmentVariable": "PNPM_SHARED_STORE_DIR",
      "scope": "host-user",
      "trustBoundary": "same-os-user"
    },
    "owner": "pnpm",
    "virtualStore": {
      "global": false,
      "path": "node_modules/.pnpm",
      "scope": "materialization-root"
    }
  },
  "workspaceManifestContract": {
    "injectWorkspacePackages": false,
    "packages": [
      "docs",
      "docs/src/content/_assets/code",
      "examples/*",
      "packages/@livestore/adapter-cloudflare",
      "packages/@livestore/adapter-web",
      "packages/@livestore/common",
      "packages/@livestore/common-cf",
      "packages/@livestore/effect-playwright",
      "packages/@livestore/framework-toolkit",
      "packages/@livestore/livestore",
      "packages/@livestore/peer-deps",
      "packages/@livestore/react",
      "packages/@livestore/sqlite-wasm",
      "packages/@livestore/sync-cf",
      "packages/@livestore/utils",
      "packages/@livestore/utils-dev",
      "packages/@livestore/wa-sqlite",
      "packages/@livestore/webmesh",
      "packages/@local/astro-tldraw",
      "packages/@local/astro-twoslash-code",
      "packages/@local/astro-twoslash-code/example",
      "packages/@local/shared",
      "scripts",
      "tests/integration",
      "tests/package-common",
      "tests/perf",
      "tests/perf-eventlog",
      "tests/sync-provider",
      "tests/wa-sqlite"
    ]
  }
}
