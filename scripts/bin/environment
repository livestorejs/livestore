#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: environment <command>

Commands:
  export-devenv-rev  Read devenv.lock and export DEVENV_REV for GitHub Actions
  resolve-devenv     Build the pinned devenv binary and export DEVENV_BIN
EOF
}

workspace_root="${WORKSPACE_ROOT:-$(git rev-parse --show-toplevel)}"
cd "$workspace_root"
export WORKSPACE_ROOT="$workspace_root"

append_github_env() {
  local key="${1:?Missing environment variable name}"
  local value="${2:?Missing environment variable value}"

  if [[ -n "${GITHUB_ENV:-}" ]]; then
    printf '%s=%s\n' "$key" "$value" >> "$GITHUB_ENV"
  fi
}

read_devenv_rev() {
  local devenv_rev
  devenv_rev="$(jq -r .nodes.devenv.locked.rev devenv.lock)"
  if [[ -z "$devenv_rev" || "$devenv_rev" = "null" ]]; then
    echo '::error::devenv.lock missing .nodes.devenv.locked.rev' >&2
    exit 1
  fi

  printf '%s\n' "$devenv_rev"
}

export_devenv_rev() {
  local devenv_rev
  devenv_rev="$(read_devenv_rev)"
  append_github_env DEVENV_REV "$devenv_rev"
  echo "Pinned devenv rev: $devenv_rev"
}

resolve_devenv_store_path() {
  local devenv_rev="${1:?Missing devenv revision}"

  nix build \
    --accept-flake-config \
    --option extra-substituters https://devenv.cachix.org \
    --option extra-trusted-public-keys devenv.cachix.org-1:w1cLUi8dv3hnoSPGAuibQv+f9TZLr6cv/Hm9XgU50cw= \
    --no-link \
    --print-out-paths \
    "github:cachix/devenv/$devenv_rev#devenv"
}

write_diagnostics_environment() {
  local diag_root="${1:?Missing diagnostics directory}"

  {
    echo "timestamp_utc=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "runner_name=${RUNNER_NAME:-unknown}"
    echo "runner_os=${RUNNER_OS:-unknown}"
    echo "runner_arch=${RUNNER_ARCH:-unknown}"
    echo "github_job=${GITHUB_JOB:-unknown}"
    echo "github_run_id=${GITHUB_RUN_ID:-unknown}"
    echo "nix_user_conf_files=${NIX_USER_CONF_FILES:-}"
    nix --version || true
  } > "$diag_root/environment.txt" 2>&1
}

resolve_devenv() {
  local devenv_rev diag_root devenv_out devenv_bin
  devenv_rev="$(read_devenv_rev)"
  append_github_env DEVENV_REV "$devenv_rev"

  # Temporary: capture diagnostics dir for #272 root-cause analysis.
  diag_root="${NIX_STORE_DIAGNOSTICS_DIR:-${RUNNER_TEMP:-/tmp}/nix-store-diagnostics-${GITHUB_JOB:-job}-${RUNNER_OS:-unknown}-${GITHUB_RUN_ATTEMPT:-0}}"
  mkdir -p "$diag_root"
  append_github_env NIX_STORE_DIAGNOSTICS_DIR "$diag_root"
  write_diagnostics_environment "$diag_root"

  if ! devenv_out="$(resolve_devenv_store_path "$devenv_rev" 2> >(tee "$diag_root/resolve-devenv.log" >&2))"; then
    echo "::error::resolve_devenv failed. Last 30 lines of log:" >&2
    tail -30 "$diag_root/resolve-devenv.log" >&2 || true
    exit 1
  fi
  devenv_bin="$devenv_out/bin/devenv"

  # Fast validity check on the devenv store path (~1-2s vs ~25s for devenv info).
  if ! nix-store --check-validity "$devenv_out" 2>/dev/null; then
    echo "::warning::devenv store path invalid, repairing targeted path..." >&2
    nix-store --repair-path "$devenv_out" > "$diag_root/nix-store-verify-repair.log" 2>&1 || true
    rm -rf "${XDG_CACHE_HOME:-$HOME/.cache}"/nix/eval-cache-* ~/.cache/nix/eval-cache-*
    if ! devenv_out="$(resolve_devenv_store_path "$devenv_rev" 2> >(tee "$diag_root/resolve-devenv-post-repair.log" >&2))"; then
      echo "::error::resolve_devenv failed after repair. Last 30 lines of log:" >&2
      tail -30 "$diag_root/resolve-devenv-post-repair.log" >&2 || true
      exit 1
    fi
    devenv_bin="$devenv_out/bin/devenv"
  fi

  append_github_env DEVENV_BIN "$devenv_bin"
  "$devenv_bin" version | tee "$diag_root/devenv-version.txt"
}

command="${1:-}"
case "$command" in
  export-devenv-rev)
    export_devenv_rev
    ;;
  resolve-devenv)
    resolve_devenv
    ;;
  -h | --help | help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
