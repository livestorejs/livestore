#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 2 ]; then
  echo "usage: run-node-bin <package> <bin-relative-path> [args...]" >&2
  exit 64
fi

package_name="$1"
bin_relative_path="$2"
shift 2

repo_root="${WORKSPACE_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
dir="$(pwd)"

while :; do
  candidate="$dir/node_modules/$package_name/$bin_relative_path"
  if [ -f "$candidate" ]; then
    exec node "$candidate" "$@"
  fi

  if [ "$dir" = "$repo_root" ] || [ "$dir" = "/" ]; then
    break
  fi
  dir="$(dirname "$dir")"
done

fallback="$repo_root/scripts/node_modules/$package_name/$bin_relative_path"
if [ -f "$fallback" ]; then
  exec node "$fallback" "$@"
fi

echo "Could not find $package_name binary $bin_relative_path from $(pwd) or $repo_root/scripts" >&2
exit 127
