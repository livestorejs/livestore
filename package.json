    "@livestore/webmesh": "workspace:*"
  },
  "resolutions#": {
    "@livestore/*": "Needed to force Bun to install local packages"
  },
  "scripts": {
    "_build:ts": "tsc --build tsconfig.dev.json && tsc --build tsconfig.examples.json",
    "build": "bun run build:ts",
    "build:clean": "bash -c \"find {examples,packages,tests,docs} -path '*node_modules*' -prune -o \\( -name 'dist' -type d -o -name '*.tsbuildinfo' \\) -exec rm -rf {} +\"",
    "build:ts": "tsc --build tsconfig.dev.json",
    "pack:tmp": "bun pm pack --destination tmp --filename pack.tgz",
    "prepare": "husky && effect-language-service patch || true",
    "test": "CI=1 bun run --workspaces --if-present test",
    "update-lockfile": "CI=1 bun install --lockfile-only --no-progress"
  },
  "trustedDependencies": [
    "@mixedbread/cli",
    "@parcel/watcher",
    "@tailwindcss/oxide",
    "dtrace-provider",
    "esbuild",
    "msgpackr-extract",
    "protobufjs",
    "sharp",
    "workerd"
  ],
  "workspaces": [
    "scripts",
    "docs",
    "docs/src/content/_assets/code",
    "packages/@livestore/*",
    "packages/@local/*",
    "packages/@local/astro-twoslash-code/example",
    "examples/*",
    "tests/*"
  ]
}
