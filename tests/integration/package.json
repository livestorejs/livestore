{
  "name": "@local/tests-integration",
  "version": "0.0.54-dev.23",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:devtools": "playwright test --project=devtools",
    "test:misc": "playwright test --project=misc",
    "test:todomvc": "playwright test --project=todomvc",
    "upload-trace": "sh -c 'project=\"${1:?Pass project name}\"; if [ -n \"${NETLIFY_AUTH_TOKEN:-}\" ]; then pnpm dlx netlify-cli deploy --no-build --dir=playwright-report --site livestore-ci --filter @local/tests-integration --alias \"$project-$(git -C ../.. rev-parse --short HEAD)\"; else echo \"Skipping Netlify deploy: NETLIFY_AUTH_TOKEN not set\"; fi' --"
  },
  "dependencies": {
    "@livestore/adapter-cloudflare": "workspace:^",
    "@livestore/adapter-web": "workspace:^",
    "@livestore/common": "workspace:^",
    "@livestore/common-cf": "workspace:^",
    "@livestore/devtools-vite": "0.4.0-dev.25",
    "@livestore/effect-playwright": "workspace:^",
    "@livestore/livestore": "workspace:^",
    "@livestore/react": "workspace:^",
    "@livestore/sync-cf": "workspace:^",
    "@livestore/utils": "workspace:^",
    "@livestore/utils-dev": "workspace:^",
    "@local/shared": "workspace:^"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20251118.0",
    "@effect/opentelemetry": "4.0.0-beta.83",
    "@effect/platform-browser": "4.0.0-beta.83",
    "@effect/platform-bun": "4.0.0-beta.83",
    "@effect/platform-node": "4.0.0-beta.83",
