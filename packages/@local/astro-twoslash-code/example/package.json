{
  "name": "@local/astro-twoslash-code-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "snippets:build": "bun run scripts/build-snippets.ts",
    "test": "bun run snippets:build && bun run playwright test"
  },
  "dependencies": {
    "@astrojs/starlight": "0.40.0",
    "@livestore/utils": "workspace:^",
    "@local/astro-twoslash-code": "workspace:^",
    "astro": "6.4.6",
    "astro-expressive-code": "0.43.1",
    "expressive-code": "0.43.1",
    "expressive-code-twoslash": "0.5.3"
  },
  "devDependencies": {
    "@effect/ai": "0.36.0",
    "@effect/cli": "0.75.2",
    "@effect/cluster": "0.59.0",
    "@effect/experimental": "0.60.0",
    "@effect/opentelemetry": "0.63.0",
    "@effect/platform": "0.96.2",
    "@effect/platform-browser": "0.76.0",
    "@effect/platform-bun": "0.90.0",
    "@effect/platform-node": "0.107.0",
    "@effect/printer": "0.49.0",
    "@effect/printer-ansi": "0.49.0",
    "@effect/rpc": "0.75.1",
    "@effect/sql": "0.51.1",
    "@effect/typeclass": "0.40.0",
    "@effect/vitest": "0.29.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/resources": "2.8.0",
    "@playwright/test": "1.61.0",
    "@standard-schema/spec": "1.1.0",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.0",
    "effect": "3.21.4",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  },
  "$genie": {
    "source": "package.json.genie.ts",
    "warning": "DO NOT EDIT - changes will be overwritten",
    "workspaceClosureDirs": [
      "packages/@livestore/utils",
      "packages/@local/astro-twoslash-code",
      "packages/@local/astro-twoslash-code/example"
    ]
  }
