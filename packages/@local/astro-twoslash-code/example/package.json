{
  "name": "@local/astro-twoslash-code-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "snippets:build": "bun run scripts/build-snippets.ts",
    "test": "bun run snippets:build && bun run playwright test"
  },
  "dependencies": {
    "@astrojs/starlight": "0.35.2",
    "@livestore/utils": "workspace:*",
    "@local/astro-twoslash-code": "workspace:*",
    "astro": "5.13.4",
    "astro-expressive-code": "0.41.5",
    "expressive-code": "0.41.5",
    "expressive-code-twoslash": "0.5.3"
  },
  "devDependencies": {
    "@effect/ai": "0.33.2",
    "@effect/cli": "0.73.2",
    "@effect/cluster": "0.56.4",
    "@effect/experimental": "0.58.0",
    "@effect/opentelemetry": "0.61.0",
    "@effect/platform": "0.94.5",
    "@effect/platform-browser": "0.73.0",
    "@effect/platform-bun": "0.86.0",
    "@effect/platform-node": "0.104.1",
    "@effect/printer": "0.47.0",
    "@effect/printer-ansi": "0.47.0",
    "@effect/rpc": "0.73.2",
    "@effect/sql": "0.49.0",
    "@effect/typeclass": "0.38.0",
    "@effect/vitest": "0.27.0",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/resources": "2.2.0",
    "@playwright/test": "1.58.2",
    "@standard-schema/spec": "1.0.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "25.3.3",
    "effect": "3.19.19",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  },
  "$genie": {
    "source": "package.json.genie.ts",
    "warning": "DO NOT EDIT - changes will be overwritten",
    "workspaceClosureDirs": [
      "packages/@livestore/utils",
      "packages/@local/astro-twoslash-code",
      "packages/@local/astro-twoslash-code/example"
    ]
  }
}
