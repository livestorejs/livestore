{
  "name": "@local/astro-twoslash-code-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "snippets:build": "bun run scripts/build-snippets.ts",
    "test": "bun run snippets:build && bun run playwright test"
  },
  "dependencies": {
    "@astrojs/starlight": "0.35.2",
    "@livestore/utils": "workspace:^",
    "@local/astro-twoslash-code": "workspace:^",
    "astro": "5.13.4",
    "astro-expressive-code": "0.41.5",
    "expressive-code": "0.41.5",
    "expressive-code-twoslash": "0.5.3"
  },
  "devDependencies": {
    "@effect/opentelemetry": "4.0.0-beta.65",
    "@effect/platform-browser": "4.0.0-beta.65",
    "@effect/platform-bun": "4.0.0-beta.65",
    "@effect/platform-node": "4.0.0-beta.65",
    "@effect/vitest": "4.0.0-beta.65",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/resources": "2.2.0",
    "@playwright/test": "1.59.1",
    "@standard-schema/spec": "1.1.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "25.3.3",
    "effect": "4.0.0-beta.65",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  },
  "$genie": {
    "source": "package.json.genie.ts",
    "warning": "DO NOT EDIT - changes will be overwritten",
    "workspaceClosureDirs": [
      "packages/@livestore/utils",
      "packages/@local/astro-twoslash-code",
      "packages/@local/astro-twoslash-code/example"
    ]
  }
}
