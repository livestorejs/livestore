{
  "name": "@livestore/utils",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/livestorejs/livestore.git"
  },
  "files": [
    "dist",
    "package.json",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "./src/global.ts",
    "./dist/global.js"
  ],
  "react-native": "./dist/index.js",
  "exports": {
    ".": "./src/mod.ts",
    "./browser": "./src/browser/mod.ts",
    "./bun": "./src/bun/mod.ts",
    "./cuid": {
      "browser": "./src/cuid/cuid.browser.ts",
      "react-native": "./src/cuid/cuid.browser.ts",
      "default": "./src/cuid/cuid.node.ts"
    },
    "./effect": "./src/effect/mod.ts",
    "./effect/browser": "./src/browser/mod.ts",
    "./nanoid": "./src/nanoid/index.ts",
    "./node": "./src/node/mod.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/mod.d.ts",
        "default": "./dist/mod.js"
      },
      "./browser": {
        "types": "./dist/browser/mod.d.ts",
        "default": "./dist/browser/mod.js"
      },
      "./cuid": {
        "types": "./dist/cuid/cuid.node.d.ts",
        "browser": "./dist/cuid/cuid.browser.js",
        "react-native": "./dist/cuid/cuid.browser.js",
        "default": "./dist/cuid/cuid.node.js"
      },
      "./nanoid": {
        "types": "./dist/nanoid/index.d.ts",
        "default": "./dist/nanoid/index.js"
      },
      "./effect": {
        "types": "./dist/effect/mod.d.ts",
        "default": "./dist/effect/mod.js"
      },
      "./effect/browser": {
        "types": "./dist/browser/mod.d.ts",
        "default": "./dist/browser/mod.js"
      },
      "./node": {
        "types": "./dist/node/mod.d.ts",
        "default": "./dist/node/mod.js"
      },
      "./bun": {
        "types": "./dist/bun/mod.d.ts",
        "default": "./dist/bun/mod.js"
      }
    }
  },
  "scripts": {
    "test": "vitest"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.97",
    "@standard-schema/spec": "1.1.0",
    "nanoid": "5.0.9",
    "pretty-bytes": "7.0.1",
    "qrcode-generator": "2.0.4"
  },
  "devDependencies": {
    "@effect/opentelemetry": "4.0.0-beta.97",
    "@effect/platform-browser": "4.0.0-beta.97",
    "@effect/platform-bun": "4.0.0-beta.97",
    "@effect/platform-node": "4.0.0-beta.97",
    "@effect/platform-node-shared": "4.0.0-beta.97",
    "@effect/vitest": "4.0.0-beta.97",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/resources": "2.2.0",
    "@standard-schema/spec": "1.1.0",
    "@types/bun": "1.3.10",
    "@types/jsdom": "21.1.7",
    "@types/node": "25.3.3",
    "@types/web": "0.0.264",
    "effect": "4.0.0-beta.97",
    "esbuild": "0.28.0",
    "jsdom": "26.1.0",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "@effect/opentelemetry": "^4.0.0-beta.97",
    "@effect/platform-browser": "^4.0.0-beta.97",
    "@effect/platform-bun": "^4.0.0-beta.97",
    "@effect/platform-node": "^4.0.0-beta.97",
    "@effect/platform-node-shared": "^4.0.0-beta.97",
    "@effect/vitest": "^4.0.0-beta.97",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.2.0",
    "@standard-schema/spec": "^1.1.0",
    "effect": "^4.0.0-beta.97"
  },
  "$genie": {
    "source": "package.json.genie.ts",
    "warning": "DO NOT EDIT - changes will be overwritten",
    "workspaceClosureDirs": [
      "packages/@livestore/utils"
    ]
  }
}
