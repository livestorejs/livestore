{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "preserve",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsxImportSource": "solid-js",
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["./src"],
  "exclude": ["node_modules", "**/dist", "**/node_modules/.pnpm"],
  "references": [
    { "path": "../common" },
    { "path": "../adapter-web" },
    { "path": "../framework-toolkit" },
    { "path": "../livestore" },
    { "path": "../utils" },
    { "path": "../utils-dev" }
  ]
}
