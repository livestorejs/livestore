  "license": "Apache-2.0",
  "files": [
    "dist",
    "docs",
    "package.json",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/mod.ts",
    "./effect": "./src/effect/mod.ts",
