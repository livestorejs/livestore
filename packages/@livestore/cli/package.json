{
  "name": "@livestore/cli",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/livestorejs/livestore.git"
  },
  "bin": {
    "livestore": "./src/bin.ts"
  },
  "files": [
    "dist",
    "package.json",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/mod.ts"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "livestore": "./dist/bin.js"
    },
    "exports": {
      ".": "./dist/mod.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun src/bin.ts"
  },
  "dependencies": {
    "@effect/ai-openai": "4.0.0-beta.70",
    "@effect/opentelemetry": "4.0.0-beta.70",
    "@livestore/adapter-node": "workspace:^",
    "@livestore/common": "workspace:^",
    "@livestore/livestore": "workspace:^",
    "@livestore/peer-deps": "workspace:^",
    "@livestore/utils": "workspace:^",
    "effect": "4.0.0-beta.70"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.70",
    "@livestore/utils-dev": "workspace:^",
    "@types/node": "25.3.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "@effect/opentelemetry": "^4.0.0-beta.70",
    "@effect/platform-browser": "^4.0.0-beta.70",
    "@effect/platform-bun": "^4.0.0-beta.70",
    "@effect/platform-node": "^4.0.0-beta.70",
    "@effect/vitest": "^4.0.0-beta.70",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.2.0",
    "@standard-schema/spec": "^1.1.0",
    "effect": "^4.0.0-beta.70"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@mixedbread/cli",
      "@myobie/pty",
      "@parcel/watcher",
      "cbor-extract",
      "dtrace-provider",
      "esbuild",
      "msgpackr-extract",
      "node-pty",
      "protobufjs",
      "puppeteer",
      "sharp",
      "unix-dgram",
      "workerd"
    ]
  },
  "$genie": {
    "source": "package.json.genie.ts",
    "warning": "DO NOT EDIT - changes will be overwritten",
    "workspaceClosureDirs": [
      "packages/@livestore/adapter-node",
      "packages/@livestore/adapter-web",
      "packages/@livestore/cli",
      "packages/@livestore/common",
      "packages/@livestore/common-cf",
      "packages/@livestore/livestore",
      "packages/@livestore/peer-deps",
      "packages/@livestore/sqlite-wasm",
      "packages/@livestore/utils",
      "packages/@livestore/utils-dev",
      "packages/@livestore/wa-sqlite",
      "packages/@livestore/webmesh"
    ]
  }
}
