{
  "name": "@livestore/adapter-cloudflare",
  "version": "0.4.0-dev.22",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "package.json",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/mod.ts",
    "./polyfill": "./src/polyfill.ts"
