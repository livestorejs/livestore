{
  "name": "@livestore/sync-electric",
  "version": "0.4.0-dev.22",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/livestorejs/livestore.git"
  },
  "files": [
    "dist",
    "package.json",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@livestore/common": "workspace:^",
    "@livestore/utils": "workspace:^"
  },
  "devDependencies": {
    "@effect/opentelemetry": "4.0.0-beta.60",
    "@effect/platform-browser": "4.0.0-beta.60",
    "@effect/platform-bun": "4.0.0-beta.60",
    "@effect/platform-node": "4.0.0-beta.60",
    "@effect/vitest": "4.0.0-beta.60",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/resources": "2.2.0",
    "@standard-schema/spec": "1.1.0",
    "effect": "4.0.0-beta.60"
  },
  "peerDependencies": {
    "@effect/opentelemetry": "^4.0.0-beta.60",
    "@effect/platform-browser": "^4.0.0-beta.60",
    "@effect/platform-bun": "^4.0.0-beta.60",
    "@effect/platform-node": "^4.0.0-beta.60",
    "@effect/vitest": "^4.0.0-beta.60",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.2.0",
    "@standard-schema/spec": "^1.1.0",
    "effect": "^4.0.0-beta.60"
  },
  "$genie": {
    "source": "package.json.genie.ts",
    "warning": "DO NOT EDIT - changes will be overwritten",
    "workspaceClosureDirs": [
      "packages/@livestore/common",
      "packages/@livestore/sync-electric",
      "packages/@livestore/utils",
      "packages/@livestore/utils-dev",
      "packages/@livestore/webmesh"
    ]
  }
}
