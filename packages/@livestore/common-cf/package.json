{
  "name": "@livestore/common-cf",
  "version": "0.4.0-dev.24",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/livestorejs/livestore.git"
  },
  "files": [
    "dist",
    "package.json",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/mod.ts",
    "./declare": "./src/declare/mod.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/mod.js",
      "./declare": "./dist/declare/mod.js"
    }
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@cloudflare/workers-types": "4.20251118.0",
    "@livestore/utils": "workspace:^"
  },
  "devDependencies": {
    "@livestore/utils-dev": "workspace:^",
    "vitest": "3.2.4",
    "wrangler": "4.42.2"
  },
  "peerDependencies": {
    "@effect/opentelemetry": "^4.0.0-beta.60",
    "@effect/platform-browser": "^4.0.0-beta.60",
    "@effect/platform-bun": "^4.0.0-beta.60",
    "@effect/platform-node": "^4.0.0-beta.60",
    "@effect/vitest": "^4.0.0-beta.60",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.2.0",
    "@standard-schema/spec": "^1.1.0",
    "effect": "^4.0.0-beta.60"
  },
  "$genie": {
    "source": "package.json.genie.ts",
    "warning": "DO NOT EDIT - changes will be overwritten",
    "workspaceClosureDirs": [
      "packages/@livestore/common-cf",
      "packages/@livestore/utils",
      "packages/@livestore/utils-dev"
    ]
  }
}
