#!/usr/bin/env bash

# In CI, direnv should fail on errors; locally it can be lenient
CI=${CI:-0}
if [ "${CI}" = "1" ] || [ "${CI}" = "true" ] || [ "${CI}" = "yes" ]; then
  strict_env
fi

source_env_if_exists ./.envrc.generated.megarepo
# Ignore mismatched generated envrc (prevents nested megarepo leakage).
if [ -n "${MEGAREPO_ROOT_NEAREST:-}" ] && [ "${MEGAREPO_ROOT_NEAREST}" != "$(pwd -P)/" ]; then
  unset MEGAREPO_ROOT_NEAREST MEGAREPO_ROOT_OUTERMOST MEGAREPO_MEMBERS MEGAREPO_NIX_WORKSPACE
fi

use devenv ${MEGAREPO_NIX_WORKSPACE:+--override-input effect-utils path:$MEGAREPO_NIX_WORKSPACE/effect-utils}
