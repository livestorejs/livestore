#!/usr/bin/env bash

# In CI, direnv should fail on errors; locally it can be lenient
CI=${CI:-0}
if [ "${CI}" = "1" ] || [ "${CI}" = "true" ] || [ "${CI}" = "yes" ]; then
  strict_env
fi

# Load generated megarepo envrc (see effect-utils/context/monorepo-compose/megarepo.md).
if [ -f ./.envrc.generated.nix ]; then
  source_env ./.envrc.generated.nix
fi

use devenv

if [ -f ./.envrc.local ]; then
  source_env ./.envrc.local
fi
